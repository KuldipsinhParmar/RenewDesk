# Copy to .env on the server and set real values. Never commit .env.

# --- Database (required) ---
# Docker dev: DB_HOST=renewdesk_db
# VPS / same server as MySQL: DB_HOST=127.0.0.1
# Managed MySQL (RDS, DigitalOcean, etc.): use the host they give you
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=renewdesk_db
DB_USER=renewdesk_user
DB_PASS=change_me_strong_password

# --- App ---
# false on production (hides DB error details from API responses)
APP_DEBUG=false

# --- Sessions (HTTPS / reverse proxy) ---
# Leave unset: secure cookies auto-enable when HTTPS or X-Forwarded-Proto: https
# Force if your proxy does not set forwarded headers: SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SECURE=true
# Optional: share cookie across subdomains (e.g. .example.com)
# SESSION_COOKIE_DOMAIN=
